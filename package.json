{
  "name": "magistrala-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/nest-static-export.mjs",
    "dev": "NODE_OPTIONS='--max-old-space-size=3072' next dev",
    "start": "serve out",
    "deploy": "pnpm run build && wrangler deploy",
    "upload": "pnpm run build && wrangler versions upload",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "lint:fix": "biome check --write"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@takumi-rs/image-response": "^0.68.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.5.4",
    "fumadocs-mdx": "14.2.7",
    "fumadocs-ui": "16.5.4",
    "mermaid": "^11.12.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wrangler": "^4.81.1"
  },
  "packageManager": "pnpm@10.12.1"
}
